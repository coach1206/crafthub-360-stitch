# ─────────────────────────────────────────────────────────────────
# NOVEE OS Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────

# Backend server port (must not conflict with Vite on 5000)
PORT=3001

# Environment
NODE_ENV=development

# PostgreSQL connection string (leave blank to use prototype/in-memory mode)
DATABASE_URL=

# Allowed frontend origin for CORS
CORS_ORIGIN=http://localhost:5000

# ── JWT Authentication ────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -hex 64
JWT_SECRET=

# ── Auth session durations ────────────────────────────────────
STAFF_PIN_EXPIRES_IN=4h
ADMIN_SESSION_EXPIRES_IN=8h
FOUNDER_SESSION_EXPIRES_IN=2h

# ── Lockout policy ────────────────────────────────────────────
MAX_FAILED_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ── Founder Level 0 challenge ─────────────────────────────────
# REQUIRED for founder login. Set any secret string.
# Example: openssl rand -hex 32
FOUNDER_CHALLENGE_SECRET=

# ── Auth cookie ───────────────────────────────────────────────
AUTH_COOKIE_NAME=novee_auth
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# ── Dev-only: allow founder_level_0 via dev headers ──────────
# NEVER set true in production.
ALLOW_DEV_FOUNDER=false

# ── Venue identity ────────────────────────────────────────────
VENUE_ID=novee-grand-lounge
DEVICE_ID=kiosk-001

# ── Feature flags ─────────────────────────────────────────────
# Secret for signing session tokens (legacy / Phase 7)
SESSION_SECRET=

# ElevenLabs voice API key (Phase 9+)
ELEVENLABS_API_KEY=

# POS 3 provider mode: prototype | clover | toast | square
POS3_PROVIDER_MODE=prototype

# E.A.T. Command provider mode: prototype | custom
EAT_PROVIDER_MODE=prototype
