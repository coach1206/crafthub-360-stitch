# ─────────────────────────────────────────────────────────────────
# NOVEE OS Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────

# Backend server port (must not conflict with Vite on 5000)
PORT=3001

# Environment
NODE_ENV=development

# PostgreSQL connection string (leave blank to use prototype/in-memory mode)
DATABASE_URL=

# Allowed frontend origin for CORS
CORS_ORIGIN=http://localhost:5000

# ── JWT Authentication ────────────────────────────────────────
# REQUIRED in production. Generate with: openssl rand -hex 64
JWT_SECRET=

# ── Auth session durations ────────────────────────────────────
STAFF_PIN_EXPIRES_IN=4h
ADMIN_SESSION_EXPIRES_IN=8h
FOUNDER_SESSION_EXPIRES_IN=2h

# ── Lockout policy ────────────────────────────────────────────
MAX_FAILED_ATTEMPTS=5
LOCKOUT_MINUTES=15

# ── Founder Level 0 challenge ─────────────────────────────────
# REQUIRED for founder login. Set any secret string.
# Example: openssl rand -hex 32
FOUNDER_CHALLENGE_SECRET=

# ── Auth cookie ───────────────────────────────────────────────
AUTH_COOKIE_NAME=novee_auth
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# ── Dev-only: allow founder_level_0 via dev headers ──────────
# NEVER set true in production.
ALLOW_DEV_FOUNDER=false

# ── Founder env override (client-side fallback login) ────────
# Used by src/config/founderOverride.js so founder_level_0 access still
# works on static-only deployments (e.g. a Vercel preview that ships only
# the Vite `dist/` build, with no server/ backend deployed alongside it).
# Set both in the hosting provider's dashboard, never commit real values.
# WARNING: VITE_-prefixed vars are bundled into the client-side JS at
# build time — anyone with the built bundle can recover this PIN. This is
# a documented, intentional tradeoff for static-preview convenience, not
# a production-grade secret. The real founder login (email + PIN +
# FOUNDER_CHALLENGE_SECRET challenge, bcrypt-verified server-side) remains
# the secure path once the backend is deployed.
VITE_FOUNDER_ADMIN_EMAIL=
VITE_FOUNDER_ADMIN_PIN=

# ── Staff Handoff Demo Mode ───────────────────────────────────
# Set VITE_STAFF_DEMO_MODE=true to allow Staff Handoff to open
# POS3 and E.A.T. without real credentials (for live demos only).
# Always shows a clear "Demo Mode" label — never claims real auth.
VITE_STAFF_DEMO_MODE=false

# ── Venue identity ────────────────────────────────────────────
VENUE_ID=novee-grand-lounge
DEVICE_ID=kiosk-001

# ── Feature flags ─────────────────────────────────────────────
# Secret for signing session tokens (legacy / Phase 7)
SESSION_SECRET=

# ElevenLabs voice API key (Phase 9+)
ELEVENLABS_API_KEY=

# POS 3 provider mode: prototype | clover | toast | square
POS3_PROVIDER_MODE=prototype

# E.A.T. Command provider mode: prototype | custom
EAT_PROVIDER_MODE=prototype
