# ─────────────────────────────────────────────────────────────────
# NOVEE OS Backend — Environment Variables
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────

# Backend server port (must not conflict with Vite on 5000)
PORT=3001

# Environment
NODE_ENV=development

# PostgreSQL connection string (leave blank to use prototype/in-memory mode)
DATABASE_URL=

# Secret for signing session tokens (generate with: openssl rand -hex 32)
SESSION_SECRET=

# Allowed frontend origin for CORS
CORS_ORIGIN=http://localhost:5000

# ElevenLabs voice API key (Phase 8+)
ELEVENLABS_API_KEY=

# POS 3 provider mode: prototype | clover | toast | square
POS3_PROVIDER_MODE=prototype

# E.A.T. Command provider mode: prototype | custom
EAT_PROVIDER_MODE=prototype
