{
  "name": "crafthub-360-production",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev":        "vite",
    "build":      "vite build",
    "preview":    "vite preview",
    "server":     "node server/index.js",
    "dev:server": "node --watch server/index.js",
    "dev:full":   "concurrently -n FRONT,BACK -c cyan,yellow \"npm run dev\" \"npm run dev:server\""
  },
  "dependencies": {
    "react":            "^18.2.0",
    "react-dom":        "^18.2.0",
    "react-router-dom": "^6.26.2",
    "framer-motion":    "^10.12.16",
    "lucide-react":     "^0.244.0",
    "clsx":             "^1.2.1",
    "tailwind-merge":   "^1.13.0",
    "express":          "^4.18.2",
    "cors":             "^2.8.5",
    "dotenv":           "^16.3.1",
    "pg":               "^8.11.3"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer":         "^10.4.14",
    "postcss":              "^8.4.24",
    "tailwindcss":          "^3.3.2",
    "vite":                 "^4.3.9",
    "concurrently":         "^8.2.2"
  }
}
