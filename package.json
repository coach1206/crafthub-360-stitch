{
  "name": "crafthub-360-production",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "npm run build && node server/index.js",
    "server": "node server/index.js",
    "dev:server": "node --watch server/index.js",
    "dev:full": "concurrently -n FRONT,BACK -c cyan,yellow \"npm run dev\" \"npm run dev:server\"",
    "visual:smokecraft": "node scripts/smokecraftVisualProof.js",
    "visual:all": "node scripts/visualProof.js",
    "visual:passport": "node scripts/visualProof.js --family=passport",
    "visual:pos3": "node scripts/visualProof.js --family=pos3",
    "visual:eat": "node scripts/visualProof.js --family=eat",
    "visual:dayone360": "node scripts/visualProof.js --family=dayone360",
    "visual:crafthub": "node scripts/visualProof.js --family=crafthub"
  },
  "dependencies": {
    "bcrypt": "^6.0.0",
    "clsx": "^1.2.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "framer-motion": "^10.12.16",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.244.0",
    "node-cron": "^4.2.1",
    "pg": "^8.11.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.26.2",
    "tailwind-merge": "^1.13.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.4.14",
    "concurrently": "^8.2.2",
    "playwright": "^1.61.1",
    "postcss": "^8.4.24",
    "tailwindcss": "^3.3.2",
    "vite": "^4.3.9"
  }
}
